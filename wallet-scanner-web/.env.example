# Aegis Solana Scanner — Environment Configuration
# Copy this file to .env.local and fill in your actual values.
# NEVER commit your real API keys to version control.

# Primary Solana RPC URL
# Sign up at https://www.helius.dev/ for a free API key
# Format: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
